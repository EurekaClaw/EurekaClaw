# Protect UI files on chenggong branch from being overwritten during merges.
# Requires local merge driver — run once per clone:
#   git config merge.ui-keep.driver true
#
# With this in place, `git merge origin/main` will never touch these files.
frontend/app.js           merge=ui-keep
frontend/index.html       merge=ui-keep
frontend/styles.css       merge=ui-keep
eurekaclaw/ui/static/app.js     merge=ui-keep
eurekaclaw/ui/static/index.html merge=ui-keep
eurekaclaw/ui/static/styles.css merge=ui-keep
eurekaclaw/ui/server.py         merge=ui-keep
